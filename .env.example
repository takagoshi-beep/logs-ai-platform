APP_ENV=dev
STORAGE_PROVIDER=sqlite
SQLITE_PATH=data/sqlite/logsys.db
POSTGRES_URL=

GOOGLE_DRIVE_ENABLED=true
GOOGLE_SHEETS_ENABLED=true
GOOGLE_OAUTH_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Set actual Drive folder IDs in local/cloud environment only.
# GOOGLE_DRIVE_FOLDER_ID should be the target folder used for real OAuth-backed sync.
# GOOGLE_CREDENTIALS_PATH should point to the downloaded OAuth client JSON.
# GOOGLE_TOKEN_PATH is generated after running scripts/google_drive_oauth.py.
GOOGLE_DRIVE_LOGSYS_FOLDER_ID=
GOOGLE_DRIVE_SALES_FOLDER_ID=
