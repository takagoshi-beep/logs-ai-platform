+                    'FROM products ORDER BY "ID" DESC LIMIT %s',
+                    (limit,),
+                )
+                rows = cur.fetchall()
+                columns = [desc[0] for desc in cur.description]
+        finally:
+            conn.close()
+    except Exception as e:
