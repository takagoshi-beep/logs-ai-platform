+    captured = {}
+
+    def _fake_query(self, limit=10, owner_name=None):
+        captured["owner_name"] = owner_name
+        return [{"id": "7722"}]
+
+    monkeypatch.setattr(ProjectService, "_query_projects_from_db", _fake_query)
