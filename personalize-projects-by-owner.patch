         conn = get_connection()
         try:
             with conn.cursor() as cur:
-                cur.execute('SELECT DISTINCT "ID" FROM purchase_orders ORDER BY "ID" DESC LIMIT %s', (limit,))
+                if owner_name:
+                    cur.execute(
