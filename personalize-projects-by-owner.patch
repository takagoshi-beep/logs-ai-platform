+                        'WHERE "営業担当者名" = %s OR "営業事務担当者名" = %s '
+                        'ORDER BY "ID" DESC LIMIT %s',
+                        (owner_name, owner_name, limit),
+                    )
+                else:
+                    cur.execute('SELECT DISTINCT "ID" FROM purchase_orders ORDER BY "ID" DESC LIMIT %s', (limit,))
                 rows = cur.fetchall()
             return [{"id": row[0]} for row in rows]
